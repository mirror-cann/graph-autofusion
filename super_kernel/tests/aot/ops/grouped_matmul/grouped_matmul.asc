#include "common/kernel_sk_common.h"
#include "grouped_matmul_tiling.h"
#include "grouped_matmul_utils.h"
#include "grouped_matmul.h"

using namespace AscendC;
using namespace matmul;
using namespace GROUPED_MATMUL;

#ifndef FORMAT_ND
    #define FORMAT_ND 0
#endif
#ifndef FORMAT_FRACTAL_NZ
    #define FORMAT_FRACTAL_NZ 29
#endif

#define FORMAT_WEIGHT FORMAT_ND

#if defined(FORMAT_WEIGHT) && FORMAT_WEIGHT == FORMAT_FRACTAL_NZ
constexpr CubeFormat wFormat = CubeFormat::NZ;
constexpr MatmulConfig matmulCFG = NZ_CFG_MDL;
#else
constexpr CubeFormat wFormat = CubeFormat::ND;
constexpr MatmulConfig matmulCFG = CFG_MDL;
#endif

#if defined(GMM_ANTI_QUANT_A8W4_MSD)
constexpr MatmulConfig A8W4_GMM_CFG_MDL = GetNormalConfig();
constexpr auto GetMmCFG() { 
    auto CFG = CFG_MDL;
    CFG.isPartialOutput = true;
    return CFG;
}
constexpr MatmulConfig A8W4_GMM_CFG_MDL_NEW = GetMmCFG();
#endif
template <typename DTYPE_X, bool trans = false>
using xType = MatmulType<AscendC::TPosition::GM, CubeFormat::ND, DTYPE_X, trans>;

template <typename DTYPE_WEIGHT, bool trans = false>
using xTypeMSD = MatmulType<AscendC::TPosition::GM, CubeFormat::ND, DTYPE_WEIGHT, trans>;

template <typename DTYPE_X, bool trans = false>
using weightType = MatmulType<AscendC::TPosition::GM, wFormat, DTYPE_X, trans>;

template <typename DTYPE_WEIGHT, bool trans = false>
using weightTypeMSD = MatmulType<AscendC::TPosition::GM, wFormat, DTYPE_WEIGHT, trans>;

template <typename MM_DTYPE_Y>
using yType = MatmulType<AscendC::TPosition::GM, CubeFormat::ND, MM_DTYPE_Y>;

using yTypeMSD = MatmulType<AscendC::TPosition::GM, CubeFormat::ND, int32_t>;

template <typename DTYPE_BIAS>
using biasType = MatmulType<AscendC::TPosition::GM, CubeFormat::ND, DTYPE_BIAS>;

template <typename DTYPE_X, typename DTYPE_Y, typename DTYPE_WEIGHT, typename MM_DTYPE_Y, typename DTYPE_BIAS, typename DTYPE_SCALE>
__global__ __aicore__ void grouped_matmul(GM_ADDR x, GM_ADDR weight, GM_ADDR bias, GM_ADDR scale,
                                          GM_ADDR offset, GM_ADDR antiquantScale, GM_ADDR antiquantOffset,
                                          GM_ADDR groupList, GM_ADDR perTokenScale, GM_ADDR y,
                                          GM_ADDR workspace, GMMTilingData tiling) {
  KERNEL_TASK_TYPE_DEFAULT(KERNEL_TYPE_MIX_AIC_1_0);
  {
    TPipe tPipe;
    AscendCUtils::SetOverflow(1);
    GM_ADDR user1 = GetUserWorkspace(workspace);
    using matmulType = MMImplType<xType<DTYPE_X, false>, weightType<DTYPE_X, false>, yType<MM_DTYPE_Y>, biasType<DTYPE_BIAS>, matmulCFGUnitFlag>;
    typename matmulType::MT mm;
    mm.SetSubBlockIdx(0);
    mm.Init(&tiling.mmTilingData, &tPipe);
    GMMCompute<matmulType, GMMBaseParams, DTYPE_WEIGHT, DTYPE_Y, DTYPE_SCALE, false> computeOp(mm);
    computeOp.Init(x, weight, bias, scale, offset, antiquantScale, antiquantOffset, groupList, perTokenScale,
                   y, user1,  &tiling.gmmBaseParams, &tiling.mmTilingData, &tPipe);
    GMMProcess<decltype(computeOp), GMMBaseParams, int32_t> op(computeOp);
    op.Init(&tiling.gmmBaseParams, &tiling.mmTilingData, (const int32_t *)&tiling.gmmArray, groupList);
    op.Process();
  }
  pipe_barrier(PIPE_ALL);
}

#ifdef __DAV_CUBE__
inline __aicore__ void grouped_matmul_half_sk_impl(__gm__ uint64_t *param){
  using DTYPE_X = half;
  using DTYPE_Y = half;
  using DTYPE_WEIGHT = half;
  using MM_DTYPE_Y = half;
  using DTYPE_BIAS = half;
  using DTYPE_SCALE = half;

  GM_ADDR x = (GM_ADDR)param[0];
  GM_ADDR weight = (GM_ADDR)param[1];
  GM_ADDR bias = (GM_ADDR)param[2];
  GM_ADDR scale = (GM_ADDR)param[3];
  GM_ADDR offset = (GM_ADDR)param[4];
  GM_ADDR antiquantScale = (GM_ADDR)param[5];
  GM_ADDR antiquantOffset = (GM_ADDR)param[6];
  GM_ADDR groupList = (GM_ADDR)param[7];
  GM_ADDR perTokenScale = (GM_ADDR)param[8];
  GM_ADDR y = (GM_ADDR)param[9];
  GM_ADDR workspace = (GM_ADDR)param[10];
  GMMTilingData *tiling;
  GET_STRUCT_PTR(param + 11, tiling);
  TPipe tPipe;
  AscendCUtils::SetOverflow(1);
  GM_ADDR user1 = GetUserWorkspace(workspace);
  using matmulType = MMImplType<xType<DTYPE_X, false>, weightType<DTYPE_X, false>, yType<MM_DTYPE_Y>, biasType<DTYPE_BIAS>, matmulCFGUnitFlag>;
  typename matmulType::MT mm;
  mm.SetSubBlockIdx(0);
  mm.Init(&tiling->mmTilingData, &tPipe);
  GMMCompute<matmulType, GMMBaseParams, DTYPE_WEIGHT, DTYPE_Y, DTYPE_SCALE, false> computeOp(mm);
  computeOp.Init(x, weight, bias, scale, offset, antiquantScale, antiquantOffset, groupList, perTokenScale,
                 y, user1,  &tiling->gmmBaseParams, &tiling->mmTilingData, &tPipe);
  GMMProcess<decltype(computeOp), GMMBaseParams, int32_t> op(computeOp);
  op.Init(&tiling->gmmBaseParams, &tiling->mmTilingData, (const int32_t *)&tiling->gmmArray, groupList);
  op.Process();
}

extern "C" __spk__ __aicore__ void grouped_matmul_half_sk(__gm__ uint64_t *param)
{
  grouped_matmul_half_sk_impl(param);
}
extern "C" __spk__ __aicore__ void grouped_matmul_half_sk1(__gm__ uint64_t *param)
{
  grouped_matmul_half_sk_impl(param);
}
extern "C" __spk__ __aicore__ void grouped_matmul_half_sk2(__gm__ uint64_t *param)
{
  grouped_matmul_half_sk_impl(param);
}
extern "C" __spk__ __aicore__ void grouped_matmul_half_sk3(__gm__ uint64_t *param)
{
  grouped_matmul_half_sk_impl(param);
}

static const struct FunLevelMixCoreType kernel_type __attribute__ ((used, section (".ascend.meta.grouped_matmul_half_sk_mix_aic"))) = { {{F_TYPE_KTYPE, sizeof(unsigned int)}, K_TYPE_MIX_AIC_MAIN}, {{F_TYPE_MIX_TASK_RATION, sizeof(unsigned int)}, 1, 0} };
static const struct FunLevelMixCoreType kernel_type1 __attribute__ ((used, section (".ascend.meta.grouped_matmul_half_sk1_mix_aic"))) = { {{F_TYPE_KTYPE, sizeof(unsigned int)}, K_TYPE_MIX_AIC_MAIN}, {{F_TYPE_MIX_TASK_RATION, sizeof(unsigned int)}, 1, 0} };
static const struct FunLevelMixCoreType kernel_type2 __attribute__ ((used, section (".ascend.meta.grouped_matmul_half_sk2_mix_aic"))) = { {{F_TYPE_KTYPE, sizeof(unsigned int)}, K_TYPE_MIX_AIC_MAIN}, {{F_TYPE_MIX_TASK_RATION, sizeof(unsigned int)}, 1, 0} };
static const struct FunLevelMixCoreType kernel_type3 __attribute__ ((used, section (".ascend.meta.grouped_matmul_half_sk3_mix_aic"))) = { {{F_TYPE_KTYPE, sizeof(unsigned int)}, K_TYPE_MIX_AIC_MAIN}, {{F_TYPE_MIX_TASK_RATION, sizeof(unsigned int)}, 1, 0} };

#endif

void GroupedMatmulKernel(uint32_t block_dim, void *stream,
                         uint8_t *x, uint8_t *weight, uint8_t *bias, uint8_t *scale,
                         uint8_t *offset, uint8_t *antiquantScale, uint8_t *antiquantOffset,
                         uint8_t *groupList, uint8_t *perTokenScale, uint8_t *y,
                         uint8_t *workspace, const GMMTilingData &tiling)
{
  grouped_matmul<half, half, half, half, half, half><<<block_dim, nullptr, stream>>>(x, weight, bias, scale,
    offset, antiquantScale, antiquantOffset, 
    groupList, perTokenScale, y,
    workspace, tiling);
}
