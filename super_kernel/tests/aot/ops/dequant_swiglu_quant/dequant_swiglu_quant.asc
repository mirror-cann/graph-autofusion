/*!
 * \file dequant_swiglu_quant.cpp
 * \brief
 */
#include "kernel_operator.h"
#include "dequant_swiglu_quant_tiling.h"
#include "kernel_tiling/kernel_tiling.h"
#include "dequant_swiglu_quant.h"
#include "dequant_swiglu_quant_dynamic_bf16.hpp"
#include "common/kernel_sk_common.h"

using namespace AscendC;

template<typename T>
__global__ __aicore__ void dequant_swiglu_quant(GM_ADDR xGM, GM_ADDR weightSscaleGM,
                                                       GM_ADDR activationScaleGM, GM_ADDR biasGM,
                                                       GM_ADDR quantScaleGM, GM_ADDR quantOffsetGM,
                                                       GM_ADDR groupIndex, GM_ADDR yGM, GM_ADDR scaleGM,
                                                       GM_ADDR workspace, T inTiling)
{
    TPipe pipe;
    if constexpr (std::is_same<T, SwiGluTilingData>::value){
        SwiGluTilingData &tiling = inTiling;
        DequantSwigluQuant::DequantSwigluQuantDynamicBF16<half, float, half, int8_t, 1, 0> op;
        op.Init(xGM, weightSscaleGM, activationScaleGM, biasGM, quantScaleGM, quantOffsetGM, yGM, scaleGM, workspace,
                &tiling, &(pipe));
        op.Process();
    }else{
        GET_TILING_STR(T, inTiling, tiling);
        DequantSwigluQuantOps::DequantSwigluQuantBase<bfloat16_t, float, int64_t, int32_t> op(&pipe);
        op.Init(xGM, weightSscaleGM, activationScaleGM, biasGM, quantScaleGM, quantOffsetGM, groupIndex, yGM, scaleGM,
                &tiling);
        op.Process();
    }
    
    pipe_barrier(PIPE_ALL);
}

void DequantSwiGluQuantDynamicKernel(uint32_t blockDim, void *stream,
                                         uint8_t *xGM, uint8_t *weightSscaleGM,
                                         uint8_t *activationScaleGM, uint8_t *biasGM,
                                         uint8_t *quantScaleGM, uint8_t *quantOffsetGM,
                                         uint8_t *groupIndex, uint8_t *yGM, uint8_t *scaleGM,
                                         uint8_t *workspace, const SwiGluTilingData &tiling)
{
dequant_swiglu_quant<SwiGluTilingData><<<blockDim, nullptr, stream>>>(xGM, weightSscaleGM,
                                                            activationScaleGM, biasGM,
                                                            quantScaleGM, quantOffsetGM,
                                                            groupIndex, yGM, scaleGM,
                                                            workspace, tiling);
}

void DequantSwiGluQuantDynamicKernel(uint32_t blockDim, void *stream,
                                         uint8_t *xGM, uint8_t *weightSscaleGM,
                                         uint8_t *activationScaleGM, uint8_t *biasGM,
                                         uint8_t *quantScaleGM, uint8_t *quantOffsetGM,
                                         uint8_t *groupIndex, uint8_t *yGM, uint8_t *scaleGM,
                                         uint8_t *workspace, const DequantSwigluQuantBaseTilingData &tiling)
{
dequant_swiglu_quant<DequantSwigluQuantBaseTilingData><<<blockDim, nullptr, stream>>>(xGM, weightSscaleGM,
                                                            activationScaleGM, biasGM,
                                                            quantScaleGM, quantOffsetGM,
                                                            groupIndex, yGM, scaleGM,
                                                            workspace, tiling);
}

#ifdef __DAV_VEC__
inline __aicore__ void dequant_swiglu_quant_dynamic_bf16_sk_impl(__gm__ uint64_t *param)
{
    GM_ADDR xGM = (GM_ADDR)param[0];
    GM_ADDR weightSscaleGM = (GM_ADDR)param[1];
    GM_ADDR activationScaleGM = (GM_ADDR)param[2];
    GM_ADDR biasGM = (GM_ADDR)param[3];
    GM_ADDR quantScaleGM = (GM_ADDR)param[4];
    GM_ADDR quantOffsetGM = (GM_ADDR)param[5];
    GM_ADDR groupIndex = (GM_ADDR)param[6];
    GM_ADDR yGM = (GM_ADDR)param[7];
    GM_ADDR scaleGM = (GM_ADDR)param[8];
    GM_ADDR workspace = (GM_ADDR)param[9];
    SwiGluTilingData *inTiling;
    GET_STRUCT_PTR(param + 10, inTiling);

    SwiGluTilingData* &tiling = inTiling;

    TPipe pipe;
    DequantSwigluQuant::DequantSwigluQuantDynamicBF16<half, float, half, int8_t, 1, 0> op;
    op.Init(xGM, weightSscaleGM, activationScaleGM, biasGM, quantScaleGM, quantOffsetGM, yGM, scaleGM, workspace,
            tiling, &(pipe));
    op.Process();
}
inline __aicore__ void dequant_swiglu_quant_dynamic_int32_sk_impl(__gm__ uint64_t *param)
{
    GM_ADDR xGM = (GM_ADDR)param[0];
    GM_ADDR weightSscaleGM = (GM_ADDR)param[1];
    GM_ADDR activationScaleGM = (GM_ADDR)param[2];
    GM_ADDR biasGM = (GM_ADDR)param[3];
    GM_ADDR quantScaleGM = (GM_ADDR)param[4];
    GM_ADDR quantOffsetGM = (GM_ADDR)param[5];
    GM_ADDR groupIndex = (GM_ADDR)param[6];
    GM_ADDR yGM = (GM_ADDR)param[7];
    GM_ADDR scaleGM = (GM_ADDR)param[8];
    GM_ADDR workspace = (GM_ADDR)param[9];
    DequantSwigluQuantBaseTilingData *inTiling;
    GET_STRUCT_PTR(param + 10, inTiling);

    GET_TILING_PTR(DequantSwigluQuantBaseTilingData*, inTiling, tiling);

    TPipe pipe;
    DequantSwigluQuantOps::DequantSwigluQuantBase<bfloat16_t, float, int64_t, int32_t> op(&pipe);
    op.Init(xGM, weightSscaleGM, activationScaleGM, biasGM, quantScaleGM, quantOffsetGM, groupIndex, yGM, scaleGM,
            tiling);
    op.Process();
}
extern "C" __spk__ __aicore__ void dequant_swiglu_quant_dynamic_bf16_sk(__gm__ uint64_t *param)
{
    dequant_swiglu_quant_dynamic_bf16_sk_impl(param);
}
