#include "kernel_operator.h"
#include "common/kernel_sk_common.h"


template<typename T, uint8_t aic, uint8_t aiv>
__aicore__ inline void matmul_add_impl(GM_ADDR x, GM_ADDR y)
{
  {
    AscendC::TPipe pipe;
    AscendC::GlobalTensor<T> xGm;
    AscendC::GlobalTensor<T> yGm;
    xGm.SetGlobalBuffer(reinterpret_cast<__gm__ T *>(x), 4096);
    yGm.SetGlobalBuffer(reinterpret_cast<__gm__ T *>(y), 4096);
    if ASCEND_IS_AIC {
      uint32_t block_len = 2560 / sizeof(T) / AscendC::GetBlockNum();
      for (int i = 0; i < block_len; i++) {
        yGm(block_len * AscendC::GetBlockIdx() + i) = xGm(block_len * AscendC::GetBlockIdx() + i) + 1;
      }
      //AscendC::SyncAll<false>(); // cube
      AscendC::SetFlag<AscendC::HardEvent::S_MTE2>(0);
      AscendC::WaitFlag<AscendC::HardEvent::S_MTE2>(0);
      AscendC::SetFlag<AscendC::HardEvent::MTE2_FIX>(0);
      AscendC::WaitFlag<AscendC::HardEvent::MTE2_FIX>(0);
      AscendC::CrossCoreSetFlag<2, PIPE_FIX>(0);
    }
    if ASCEND_IS_AIV {
      //AscendC::SyncAll<false>(); // vec
      AscendC::CrossCoreWaitFlag<2, PIPE_S>(0);
      uint32_t block_len = 2560 / sizeof(T) / AscendC::GetBlockNum() / aiv;
      for (int i = 0; i < block_len; i++) {
        yGm(block_len * AscendC::GetBlockIdx() + i) += 3;
      }
    }
  }
}
template<typename T, uint8_t aic, uint8_t aiv>
__global__ __mix__(aic, aiv) void matmul_add(GM_ADDR x, GM_ADDR y)
{
  matmul_add_impl<T, aic, aiv>(x, y);
  pipe_barrier(PIPE_ALL);
}

