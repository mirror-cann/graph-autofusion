extern "C" __spk__ __aicore__ void matmul_add_uint8_sk(__gm__ uint64_t *param)
{
    GM_ADDR x = (GM_ADDR)param[0];
    GM_ADDR y = (GM_ADDR)param[1];
    matmul_add_impl<uint8_t, 1, 2>(x, y);
}
extern "C" __spk__ __aicore__ void matmul_add_uint8_sk1(__gm__ uint64_t *param)
{
    GM_ADDR x = (GM_ADDR)param[0];
    GM_ADDR y = (GM_ADDR)param[1];
    matmul_add_impl<uint8_t, 1, 2>(x, y);
}
extern "C" __spk__ __aicore__ void matmul_add_uint8_sk2(__gm__ uint64_t *param)
