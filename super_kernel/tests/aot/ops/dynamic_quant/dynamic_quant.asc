/*!
 * \file dynamic_quant.asc
 * \brief
 */
#include "common/kernel_sk_common.h"
#include "dynamic_quant_tiling.h"
#include "kernel_operator.h"
#include "dynamic_quant.h"
#include "dynamic_quant_db.h"
#include "dynamic_quant_large_shape_opt.h"
#include "dynamic_quant_moe.h"
#include "dynamic_quant_moe_large_shape.h"

using namespace AscendC;
using namespace DynamicQuantNDOpt;

extern "C" __global__ __aicore__ void dynamic_quant(
    GM_ADDR x, GM_ADDR smooth_scales, GM_ADDR group_index, GM_ADDR y, GM_ADDR scale, GM_ADDR workSpace, DynamicQuantTilingData inTiling)
{
    GET_TILING_STR(DynamicQuantTilingData, inTiling, tiling);
    if (x == nullptr || y == nullptr || scale == nullptr) {
        return;
    }
    if (GetBlockIdx() >= tiling.coreNum) {
        return;
    }
    TPipe pipe;
    DynamicQuantDbOpt<DTYPE_X, DTYPE_Y> op(&pipe);
    op.Init(x, smooth_scales, y, scale, nullptr, workSpace, &tiling);
    op.Process();
}

void DynamicQuantKernel(uint32_t block_dim, void *stream,
                         uint8_t *x, uint8_t *smooth_scales, uint8_t *group_index, uint8_t *y,
                         uint8_t *scale, uint8_t *workSpace, const DynamicQuantTilingData& tiling)
{
  dynamic_quant<<<block_dim, nullptr, stream>>>(x, smooth_scales, group_index, y, scale, workSpace, tiling);
}

#ifdef __DAV_VEC__
inline __aicore__ void dynamic_quant_sk_impl(__gm__ uint64_t *param){
    GM_ADDR x = (GM_ADDR)(param[0]);
    GM_ADDR smooth_scales = (GM_ADDR)(param[1]);
    GM_ADDR group_index = (GM_ADDR)(param[2]);
    GM_ADDR y = (GM_ADDR)(param[3]);
    GM_ADDR scale = (GM_ADDR)(param[4]);
    GM_ADDR workSpace = (GM_ADDR)(param[5]);
    DynamicQuantTilingData *inTiling;
    GET_STRUCT_PTR(param + 6, inTiling);

    GET_TILING_PTR(DynamicQuantTilingData*, inTiling, tiling);
    
    if (x == nullptr || y == nullptr || scale == nullptr) {
        return;
    }
    if (GetBlockIdx() >= tiling->coreNum) {
        return;
    }
    TPipe pipe;
    DynamicQuantDbOpt<DTYPE_X, DTYPE_Y> op(&pipe);
    op.Init(x, smooth_scales, y, scale, nullptr, workSpace, tiling);
    op.Process();
}

extern "C" __spk__ __aicore__ void dynamic_quant_sk(__gm__ uint64_t *param){
    dynamic_quant_sk_impl(param);
}
extern "C" __spk__ __aicore__ void dynamic_quant_sk1(__gm__ uint64_t *param){
    dynamic_quant_sk_impl(param);
}
extern "C" __spk__ __aicore__ void dynamic_quant_sk2(__gm__ uint64_t *param){
    dynamic_quant_sk_impl(param);
}
extern "C" __spk__ __aicore__ void dynamic_quant_sk3(__gm__ uint64_t *param){
    dynamic_quant_sk_impl(param);
}

static const struct FunLevelKType kernel_type __attribute__ ((used, section (".ascend.meta.dynamic_quant_sk_mix_aiv"))) = { {{F_TYPE_KTYPE, sizeof(unsigned int)}, K_TYPE_AIV} };
static const struct FunLevelKType kernel_type1 __attribute__ ((used, section (".ascend.meta.dynamic_quant_sk1_mix_aiv"))) = { {{F_TYPE_KTYPE, sizeof(unsigned int)}, K_TYPE_AIV} };
static const struct FunLevelKType kernel_type2 __attribute__ ((used, section (".ascend.meta.dynamic_quant_sk2_mix_aiv"))) = { {{F_TYPE_KTYPE, sizeof(unsigned int)}, K_TYPE_AIV} };
static const struct FunLevelKType kernel_type3 __attribute__ ((used, section (".ascend.meta.dynamic_quant_sk3_mix_aiv"))) = { {{F_TYPE_KTYPE, sizeof(unsigned int)}, K_TYPE_AIV} };
#endif