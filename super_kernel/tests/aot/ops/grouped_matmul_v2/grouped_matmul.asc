namespace {
#if defined(FORMAT_WEIGHT) && FORMAT_WEIGHT == FORMAT_FRACTAL_NZ
constexpr CubeFormat wFormat = CubeFormat::NZ;
constexpr MatmulConfig matmulCFG = NZ_CFG_MDL;
#else
constexpr CubeFormat wFormat = CubeFormat::ND;
constexpr MatmulConfig matmulCFG = CFG_MDL;
#endif

#if defined(GMM_ANTI_QUANT_A8W4_MSD)
constexpr MatmulConfig A8W4_GMM_CFG_MDL = GetNormalConfig();
constexpr auto GetMmCFG() {
    auto CFG = CFG_MDL;
    CFG.isPartialOutput = true;
    return CFG;
}
constexpr MatmulConfig A8W4_GMM_CFG_MDL_NEW = GetMmCFG();
#endif
}

template <typename DTYPE_X, bool trans = false>
using xType = MatmulType<AscendC::TPosition::GM, CubeFormat::ND, DTYPE_X, trans>;

template <typename DTYPE_WEIGHT, bool trans = false>
using xTypeMSD = MatmulType<AscendC::TPosition::GM, CubeFormat::ND, DTYPE_WEIGHT, trans>;

template <typename DTYPE_X, bool trans = false>
using weightType = MatmulType<AscendC::TPosition::GM, wFormat, DTYPE_X, trans>;

template <typename DTYPE_WEIGHT, bool trans = false>
using weightTypeMSD = MatmulType<AscendC::TPosition::GM, wFormat, DTYPE_WEIGHT, trans>;

template <typename MM_DTYPE_Y>
using yType = MatmulType<AscendC::TPosition::GM, CubeFormat::ND, MM_DTYPE_Y>;

using yTypeMSD = MatmulType<AscendC::TPosition::GM, CubeFormat::ND, int32_t>;

template <typename DTYPE_BIAS>
using biasType = MatmulType<AscendC::TPosition::GM, CubeFormat::ND, DTYPE_BIAS>;

namespace {
    template <typename DTYPE_X, typename DTYPE_Y, typename DTYPE_WEIGHT, typename MM_DTYPE_Y, typename DTYPE_BIAS, typename DTYPE_SCALE>
    __aicore__ inline static constexpr MatmulApiStaticTiling GetGmmMatmulApiTiling(bool isND2NZ, bool transB) {
        MatmulConfig conf = GenGmmConf(isND2NZ);
        MatmulApiStaticTiling staticTilingTmp;
        if (transB) {
            staticTilingTmp = GetMatmulApiTiling<xType<DTYPE_X, false>, weightType<DTYPE_WEIGHT, true>, yType<MM_DTYPE_Y>, biasType<DTYPE_BIAS>>(conf);
        } else {
            staticTilingTmp = GetMatmulApiTiling<xType<DTYPE_X, false>, weightType<DTYPE_WEIGHT, false>, yType<MM_DTYPE_Y>, biasType<DTYPE_BIAS>>(conf);
        }
        staticTilingTmp.depthA1 = STATIC_TILING_DEPTH_A1_B1;
        staticTilingTmp.depthB1 = STATIC_TILING_DEPTH_A1_B1;
        staticTilingTmp.stepM = 1;
        staticTilingTmp.stepN = 1;
        staticTilingTmp.stepKa = STATIC_TILING_STEP_KA_KB;
        staticTilingTmp.stepKb = STATIC_TILING_STEP_KA_KB;
        staticTilingTmp.dbL0A = DOUBLE_BUFFER_L0A_L0B;
        staticTilingTmp.dbL0B = DOUBLE_BUFFER_L0A_L0B;
        staticTilingTmp.dbL0C = 1;
        return staticTilingTmp;
    }
#if defined(FORMAT_WEIGHT) && FORMAT_WEIGHT == FORMAT_FRACTAL_NZ
    constexpr bool isWeightNZ = true;
#else
    constexpr bool isWeightNZ = false;
#endif
    // constexpr static auto staticCFG = GetGmmMatmulApiTiling<DTYPE_X, DTYPE_Y, DTYPE_WEIGHT, MM_DTYPE_Y, DTYPE_BIAS, DTYPE_SCALE>(isWeightNZ, false);
    // constexpr static auto staticCFGtransB = GetGmmMatmulApiTiling<DTYPE_X, DTYPE_Y, DTYPE_WEIGHT, MM_DTYPE_Y, DTYPE_BIAS, DTYPE_SCALE>(isWeightNZ, true);
} // namespace

#define GMM_CUBE_STATIC_TILING_IMP(processClass, transA, transB, sync, cfg)                                        \
    do {                                                                                                           \
        if ASCEND_IS_AIV {                                                                                         \
            return;                                                                                                \
        }                                                                                                          \
        using matmulType = MMImplType<xType<DTYPE_X, transA>, weightType<DTYPE_WEIGHT, transB>, yType<MM_DTYPE_Y>, biasType<DTYPE_BIAS>, cfg>;                    \
        typename matmulType::MT mm;                                                                                         \
        mm.SetSubBlockIdx(0);                                                                                      \
        mm.Init((TCubeTiling*)nullptr, &tPipe);                                                                    \
        GMMCompute<matmulType, DTYPE_WEIGHT, DTYPE_Y, DTYPE_SCALE, DTYPE_BIAS, sync> computeOp(mm);                                                                \
        computeOp.Init(x, weight, bias, scale, offset, antiquantScale, antiquantOffset, groupList, perTokenScale,  \
                       y, user1,  &tiling.gmmBaseParams, nullptr, &tPipe);                                               \
        processClass<decltype(computeOp)> op(computeOp);                                                           \
        op.Init(&tiling.gmmBaseParams, nullptr, 0, groupList, &tiling);                                                   \
        op.InitStaticTiling((cfg).baseM, (cfg).baseN);                                                             \
        op.Process();                                                                                              \
    } while (0)

#define GMM_CUBE_IMP(processClass, transA, transB, sync, cfg)                                                      \
    do {                                                                                                           \
        if ASCEND_IS_AIV {                                                                                         \
            return;                                                                                                \
        }                                                                                                          \
        using matmulType = MMImplType<xType<DTYPE_X, transA>, weightType<DTYPE_WEIGHT, transB>, yType<MM_DTYPE_Y>, biasType<DTYPE_BIAS>, cfg>;                    \
        typename matmulType::MT mm;                                                                                         \
        mm.SetSubBlockIdx(0);                                                                                      \
        mm.Init(&tiling.mmTilingData, &tPipe);                                                                           \
        GMMCompute<matmulType, DTYPE_WEIGHT, DTYPE_Y, DTYPE_SCALE, DTYPE_BIAS, sync> computeOp(mm);                                                                \
        computeOp.Init(x, weight, bias, scale, offset, antiquantScale, antiquantOffset, groupList, perTokenScale,  \
                       y, user1,  &tiling.gmmBaseParams, &tiling.mmTilingData, &tPipe);                                        \
        processClass<decltype(computeOp)> op(computeOp);                                                           \
        op.Init(&tiling.gmmBaseParams, &tiling.mmTilingData, (const int32_t*)&tiling.gmmArray, groupList, &tiling);                                \
        op.Process();                                                                                              \
    } while (0)

template <typename DTYPE_X, typename DTYPE_Y, typename DTYPE_WEIGHT, typename MM_DTYPE_Y, typename DTYPE_BIAS, typename DTYPE_SCALE>
__global__ __mix__(1,0) void grouped_matmul_v2(GM_ADDR x, GM_ADDR weight, GM_ADDR bias, GM_ADDR scale,
                                            GM_ADDR offset, GM_ADDR antiquantScale, GM_ADDR antiquantOffset,
                                            GM_ADDR groupList, GM_ADDR perTokenScale, GM_ADDR y,
                                            GM_ADDR workspace, GMMTilingData inTiling) {
    // KERNEL_TASK_TYPE_DEFAULT(KERNEL_TYPE_MIX_AIC_1_0);
    TPipe tPipe;
    AscendCUtils::SetOverflow(1);
    // GM_ADDR user1 = GetUserWorkspace(workspace);
    auto user1 = workspace;

    GET_TILING_STR(GMMTilingData, inTiling, tiling);

    // constexpr static auto staticCFG = GetGmmMatmulApiTiling<DTYPE_X, DTYPE_Y, DTYPE_WEIGHT, MM_DTYPE_Y, DTYPE_BIAS, DTYPE_SCALE>(isWeightNZ, false);
    // GMM_CUBE_STATIC_TILING_IMP(GMMProcess, false, false, false, staticCFG);

    // using matmulType = MMImplType<xType<DTYPE_X, false>, weightType<DTYPE_WEIGHT, false>, yType<MM_DTYPE_Y>, biasType<DTYPE_BIAS>, staticCFG>;
    // typename matmulType::MT mm;
    // mm.SetSubBlockIdx(0);
    // mm.Init((TCubeTiling*)nullptr, &tPipe);
    // GMMCompute<matmulType, DTYPE_WEIGHT, MM_DTYPE_Y, DTYPE_SCALE, DTYPE_BIAS, false> computeOp(mm);
    // computeOp.Init(x, weight, bias, scale, offset, antiquantScale, antiquantOffset, groupList, perTokenScale,
    //                 y, user1,  &tiling.gmmBaseParams, nullptr, &tPipe);
    // GMMProcess<decltype(computeOp)> op(computeOp);
    // op.Init(&tiling.gmmBaseParams, nullptr, 0, groupList, &tiling);
    // op.InitStaticTiling((staticCFG).baseM, (staticCFG).baseN);
    // op.Process();

    GMM_CUBE_IMP(GMMProcess, false, false, false, matmulCFGUnitFlag);

    pipe_barrier(PIPE_ALL);
}

void GroupedMatmulKernelV2(uint32_t block_dim, void *stream,
                         uint8_t *x, uint8_t *weight, uint8_t *bias, uint8_t *scale,
                         uint8_t *offset, uint8_t *antiquantScale, uint8_t *antiquantOffset,
                         uint8_t *groupList, uint8_t *perTokenScale, uint8_t *y,
                         uint8_t *workspace, const GMMTilingData &tiling)
{
  grouped_matmul_v2<int8_t, int32_t, int8_t, int32_t, int32_t, uint64_t><<<block_dim, nullptr, stream>>>(x, weight, bias, scale,
    offset, antiquantScale, antiquantOffset, 
    groupList, perTokenScale, y,
    workspace, tiling);
}

#ifdef __DAV_CUBE__
inline __aicore__ void grouped_matmul_v2_sk_impl(__gm__ uint64_t *param)
{
    if ASCEND_IS_AIV {
        return;
    }
    using DTYPE_X = int8_t;
    using DTYPE_Y = int32_t;
    using DTYPE_WEIGHT = int8_t;
    using MM_DTYPE_Y = int32_t;
    using DTYPE_BIAS = int32_t;
    using DTYPE_SCALE = uint64_t;

    GM_ADDR x = (GM_ADDR)param[0];
    GM_ADDR weight = (GM_ADDR)param[1];
    GM_ADDR bias = (GM_ADDR)param[2];
    GM_ADDR scale = (GM_ADDR)param[3];
    GM_ADDR offset = (GM_ADDR)param[4];
    GM_ADDR antiquantScale = (GM_ADDR)param[5];
    GM_ADDR antiquantOffset = (GM_ADDR)param[6];
    GM_ADDR groupList = (GM_ADDR)param[7];
    GM_ADDR perTokenScale = (GM_ADDR)param[8];
    GM_ADDR y = (GM_ADDR)param[9];
    GM_ADDR workspace = (GM_ADDR)param[10];
    GMMTilingData *inTiling;
    GET_STRUCT_PTR(param + 11, inTiling);

    GET_TILING_PTR(GMMTilingData*, inTiling, tiling);

    TPipe tPipe;
    AscendCUtils::SetOverflow(1);
    auto user1 = workspace;

    // constexpr static auto staticCFG = GetGmmMatmulApiTiling<DTYPE_X, DTYPE_Y, DTYPE_WEIGHT, MM_DTYPE_Y, DTYPE_BIAS, DTYPE_SCALE>(isWeightNZ, false);
    // using matmulType = MMImplType<xType<DTYPE_X, false>, weightType<DTYPE_WEIGHT, false>, yType<MM_DTYPE_Y>, biasType<DTYPE_BIAS>, staticCFG>;
    // typename matmulType::MT mm;
    // mm.SetSubBlockIdx(0);
    // mm.Init((TCubeTiling*)nullptr, &tPipe);
    // GMMCompute<matmulType, DTYPE_WEIGHT, MM_DTYPE_Y, DTYPE_SCALE, DTYPE_BIAS, false> computeOp(mm);
    // computeOp.Init(x, weight, bias, scale, offset, antiquantScale, antiquantOffset, groupList, perTokenScale,
    //                 y, user1,  &tiling->gmmBaseParams, nullptr, &tPipe);
    // GMMProcess<decltype(computeOp)> op(computeOp);
    // op.Init(&tiling->gmmBaseParams, nullptr, 0, groupList, tiling);
    // op.InitStaticTiling((staticCFG).baseM, (staticCFG).baseN);
    // op.Process();

    if ASCEND_IS_AIV {
        return;
    }
    using matmulType = MMImplType<xType<DTYPE_X, false>, weightType<DTYPE_WEIGHT, false>, yType<MM_DTYPE_Y>, biasType<DTYPE_BIAS>, matmulCFGUnitFlag>;
    typename matmulType::MT mm;
    mm.SetSubBlockIdx(0);
    mm.Init(&tiling->mmTilingData, &tPipe);
    GMMCompute<matmulType, DTYPE_WEIGHT, DTYPE_Y, DTYPE_SCALE, DTYPE_BIAS, false> computeOp(mm);
    computeOp.Init(x, weight, bias, scale, offset, antiquantScale, antiquantOffset, groupList, perTokenScale,
                    y, user1,  &tiling->gmmBaseParams, &tiling->mmTilingData, &tPipe);
    GMMProcess<decltype(computeOp)> op(computeOp);
    op.Init(&tiling->gmmBaseParams, &tiling->mmTilingData, (const int32_t*)&tiling->gmmArray, groupList, tiling);
    op.Process();

}
extern "C" __spk__ __aicore__ void grouped_matmul_v2_sk(__gm__ uint64_t *param){
    grouped_matmul_v2_sk_impl(param);
}
extern "C" __spk__ __aicore__ void grouped_matmul_v2_sk1(__gm__ uint64_t *param){
    grouped_matmul_v2_sk_impl(param);
}
extern "C" __spk__ __aicore__ void grouped_matmul_v2_sk2(__gm__ uint64_t *param){
    grouped_matmul_v2_sk_impl(param);
}
extern "C" __spk__ __aicore__ void grouped_matmul_v2_sk3(__gm__ uint64_t *param){
    grouped_matmul_v2_sk_impl(param);
}

