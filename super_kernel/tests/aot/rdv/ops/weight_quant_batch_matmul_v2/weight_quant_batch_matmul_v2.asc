template<typename DTYPE_X, typename DTYPE_W, typename DTYPE_Y, typename T>
__global__ __mix__(1,2) void weight_quant_batch_matmul_v2(
    GM_ADDR x, GM_ADDR weight, GM_ADDR antiquantScale, GM_ADDR antiquantOffset, GM_ADDR quantScale, GM_ADDR quantOffset,
    GM_ADDR bias, GM_ADDR y, GM_ADDR workspace, T tiling)
{
    if constexpr (std::is_same<T, WeightQuantBatchMatmulV2MsdTilingData>::value)
    {
        AscendC::TPipe tPipe;
        WeightQuantBatchMatmulV2MsdMultiCoreKernel<DTYPE_X, DTYPE_W, DTYPE_X, DTYPE_Y, false, false, QuantType::PER_CHANNEL, true, QuantType::PER_TENSOR, CubeFormat::ND> op;
        op.Init(
            x, weight, antiquantScale, antiquantOffset, quantScale, quantOffset, bias, y, workspace, &tiling,
            &tPipe);
        op.Process();
    }

    else if constexpr (std::is_same<T, WeightQuantBatchMatmulV2TilingData>::value)
    {
        AscendC::TPipe tPipe;
        WeightQuantBatchMatmulV2CustomKernel<DTYPE_X, DTYPE_W, DTYPE_X, DTYPE_Y, false, false, QuantType::PER_CHANNEL, true, QuantType::PER_TENSOR> op;                                                          
        op.Init(
            x, weight, antiquantScale, antiquantOffset, quantScale, quantOffset, bias, y, workspace, &tiling,
            &tPipe);
        op.Process();
    }

    pipe_barrier(PIPE_ALL);
}

// template<typename DTYPE_X, typename DTYPE_W, typename DTYPE_Y, typename T>
__aicore__ inline void weight_quant_batch_matmul_v2_half_int8_half_mc_sk_impl(__gm__ uint64_t *param)
{
    GM_ADDR x = (GM_ADDR)param[0];
    GM_ADDR weight = (GM_ADDR)param[1];
    GM_ADDR antiquantScale = (GM_ADDR)param[2];
    GM_ADDR antiquantOffset = (GM_ADDR)param[3];
    GM_ADDR quantScale = (GM_ADDR)param[4];
    GM_ADDR quantOffset = (GM_ADDR)param[5];
    GM_ADDR bias = (GM_ADDR)param[6];
    GM_ADDR y = (GM_ADDR)param[7];
    GM_ADDR workspace = (GM_ADDR)param[8];
    WeightQuantBatchMatmulV2MsdTilingData *tiling;
    GET_STRUCT_PTR(param + 9, tiling);
    // if constexpr (std::is_same<T, WeightQuantBatchMatmulV2MsdTilingData>::value)
    // {
    AscendC::TPipe tPipe;
    WeightQuantBatchMatmulV2MsdMultiCoreKernel<half, int8_t,half, half, false, false, QuantType::PER_CHANNEL, true, QuantType::PER_TENSOR, CubeFormat::ND> op;
    op.Init(
        x, weight, antiquantScale, antiquantOffset, quantScale, quantOffset, bias, y, workspace, tiling,
        &tPipe);
    op.Process();
    // }
}

