SK_BIND(0, &rms_norm<half, half>, &rms_norm_half_half_sk, &rms_norm_half_half_sk1, &rms_norm_half_half_sk2, &rms_norm_half_half_sk3);
#endif
void RmsNormKernel(uint32_t block_dim, void *stream, uint8_t *x, uint8_t *gamma, uint8_t *y, uint8_t *rstd, const RMSNormTilingData &tiling)
{
  rms_norm<half, half><<<block_dim, nullptr, stream>>>(x, gamma, y, rstd, tiling);
}
