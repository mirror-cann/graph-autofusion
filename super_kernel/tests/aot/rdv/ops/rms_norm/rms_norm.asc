// static const struct FunLevelKType kernel_type1 __attribute__ ((used, section (".ascend.meta.rms_norm_half_half_sk1_mix_aiv"))) = { {{F_TYPE_KTYPE, sizeof(unsigned int)}, K_TYPE_AIV} };
