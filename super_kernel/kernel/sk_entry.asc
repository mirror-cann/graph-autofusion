#include "kernel_operator.h"
#include "sk_common.h"
#include <cstdio>

typedef void (*sk_sub_func)(const __gm__ void *param);

namespace AscendC {

template<bool aic_flag>
__aicore__ inline void NotifyFunc(GM_ADDR param) {
    if constexpr(aic_flag) {
        if (get_block_idx() ==0) {
            __gm__ uint64_t *notifyLock = reinterpret_cast<__gm__ uint64_t *>(param);
            *notifyLock = 1;
            dcci(notifyLock, 0, 2);
        }
    } else {
        if (AscendC::GetBlockIdx() == 0) {
            __gm__ uint64_t *notifyLock = reinterpret_cast<__gm__ uint64_t *>(param);
            *notifyLock = 1;
            dcci(notifyLock, 0, 2);
        }
    }
}

template<bool aic_flag>
__aicore__ inline void WaitFunc(GM_ADDR param) {
    if constexpr(aic_flag) {
        if (get_block_idx() ==0) {
            __gm__ uint64_t *waitLock = reinterpret_cast<__gm__ uint64_t *>(param);
            dcci(waitLock, 0, 2);
            while(*waitLock != 1) {
                dcci(waitLock, 0, 2);
            }
        }
    } else {
        if (AscendC::GetBlockIdx() == 0) {
            __gm__ uint64_t *waitLock = reinterpret_cast<__gm__ uint64_t *>(param);
            dcci(waitLock, 0, 2);
            while(*waitLock != 1) {
                dcci(waitLock, 0, 2);
            }
        }
    }
}

__aicore__ inline void AutoCoreSyncImpl(SkCoreSyncType sync_type) {
    switch (sync_type) {    
        case SkCoreSyncType::CROSS_SYNC_AIC_TO_AIC:
            if ASCEND_IS_AIC {
                ffts_cross_core_sync(PIPE_FIX, AscendC::GetffstMsg(0x0, AscendC::SYNC_AIC_FLAG));
                wait_flag_dev(AscendC::SYNC_AIC_FLAG);
            }
            break;
        case SkCoreSyncType::CROSS_SYNC_AIV_TO_AIV:
            if ASCEND_IS_AIV {
                ffts_cross_core_sync(PIPE_MTE3, AscendC::GetffstMsg(0x0, AscendC::SYNC_AIV_ONLY_ALL));
                wait_flag_dev(AscendC::SYNC_AIV_ONLY_ALL);
            }
            break;
        case SkCoreSyncType::INTER_SYNC_SET_AIC_TO_AIV:
            if ASCEND_IS_AIC {
                ffts_cross_core_sync(PIPE_MTE3, AscendC::GetffstMsg(0x02, AscendC::SYNC_AIC_AIV_FLAG));
            }
            break;
        case SkCoreSyncType::INTER_SYNC_SET_AIV_TO_AIC:
            if ASCEND_IS_AIV {
                ffts_cross_core_sync(PIPE_MTE3, AscendC::GetffstMsg(0x02, AscendC::SYNC_AIV_FLAG));
            }
            break;
        case SkCoreSyncType::INTER_SYNC_WAIT_AIC_TO_AIV:
            if ASCEND_IS_AIV {
                wait_flag_dev(AscendC::SYNC_AIC_AIV_FLAG);
            }
            break;
        case SkCoreSyncType::INTER_SYNC_WAIT_AIV_TO_AIC:
            if ASCEND_IS_AIC {
                wait_flag_dev(AscendC::SYNC_AIV_FLAG);
            }
            break;
        default:
            // 最好让它主动报一个aicore error，而不是静默失败了
            break;
        return ;
    }
}
}

template <uint8_t aic, uint8_t aiv, bool enable_debug = false>
__aicore__ inline void spk_entry_impl(GM_ADDR skDevArgs) {
    const __gm__ SkHeaderInfo *sk_header = (const __gm__ SkHeaderInfo *)skDevArgs;
    if constexpr(enable_debug){
        if(AscendC::GetBlockIdx() == 0 ){
            // print header info for debugging
            AscendC::printf("[sk inner info] sk_header addr: %p\n", sk_header);
            AscendC::printf("[sk inner info] sk_header aic_que_offset: %u\n", sk_header->aicQueOffset);
            AscendC::printf("[sk inner info] sk_header aiv_que_offset: %u\n", sk_header->aivQueOffset);
            AscendC::printf("[sk inner info] sk_header counter_offset: %u\n", sk_header->counterOffset);
            AscendC::printf("[sk inner info] sk_header ws_offset: %u\n", sk_header->wsOffset);
            AscendC::printf("[sk inner info] sk_header dfx_offset: %u\n", sk_header->dfxOffset);
            AscendC::printf("[sk inner info] sk_header node_cnt: %u\n", sk_header->nodeCnt);
            AscendC::printf("[sk inner info] sk_header total_size: %u\n", sk_header->totalSize);
        }
    }
    uint32_t que_offset = 0;
    if ASCEND_IS_AIC {
        que_offset = sk_header->aicQueOffset;
    }
    if ASCEND_IS_AIV {
        que_offset = sk_header->aivQueOffset;

    }
    const __gm__ TaskQue *taskQue = (const __gm__ TaskQue *)((const __gm__ uint8_t *)sk_header + que_offset);

    for (auto i = 0; i < taskQue->taskCnt; i++) {
        const __gm__ TaskInfo *task = &(taskQue->taskInfos[i]);
        if (task->type == SkTaskType::TYPE_PRELOAD) {
            auto block_id = AscendC::GetBlockIdx();
            if (block_id < task->numBlocks) {
                preload((const void *)(task->entry[((uint8_t)get_coreid()) % task->entryCnt]), task->args);
            }
        } else if (task->type == SkTaskType::TYPE_FUNC) {
            auto block_id = AscendC::GetBlockIdx();
            if (block_id < task->numBlocks) {
                
                __gm__ SkCounterInfo *counterInfo = (__gm__ SkCounterInfo *)((const __gm__ uint8_t *)sk_header + sk_header->counterOffset + sizeof(SkCounterInfo) * AscendC::GetBlockIdx() );
                counterInfo->index = i;
                counterInfo->launch = 1;
                counterInfo->exit = 0;
                // todo ：后续通过sk option判断是否开启dcci， 默认仅开启算子结尾的dcci
                // dcci(nullptr, 1, 2);
                ((sk_sub_func)(task->entry[((uint8_t)get_coreid()) % task->entryCnt]))((const __gm__ void *)task->args);
                if constexpr(enable_debug){
                    if ((task->debugOptions & 0x1) == 0) {
                        dcci(nullptr, 1, 2);
                    }
                }else {
                    dcci(nullptr, 1, 2);
                }
                counterInfo->launch = 0;
                counterInfo->exit = 1;
            }
        } else if (task->type == SkTaskType::TYPE_SYNC) {
            if constexpr(enable_debug) {
                if ((task->debugOptions & 0x2) != 0) {
                    if constexpr (aic == 1 && aiv == 0) {
                        ffts_cross_core_sync(PIPE_FIX, AscendC::GetffstMsg(0x0, AscendC::SYNC_AIC_FLAG));
                        wait_flag_dev(AscendC::SYNC_AIC_FLAG);
                    } else if constexpr (aic == 0 && aiv==1) {
                        ffts_cross_core_sync(PIPE_MTE3, AscendC::GetffstMsg(0x0, AscendC::SYNC_AIV_ONLY_ALL));
                        wait_flag_dev(AscendC::SYNC_AIV_ONLY_ALL);
                    } else {
                        AscendC::SyncAll<false>();
                    }
                } else {
                    AscendC::AutoCoreSyncImpl((SkCoreSyncType)task->args);
                }
            } else{
                AscendC::AutoCoreSyncImpl((SkCoreSyncType)task->args);
            }
        } else if (task->type == SkTaskType::TYPE_EVENT_NOTIFY) {
            if ASCEND_IS_AIC {
                AscendC::NotifyFunc<true>((GM_ADDR)task->args);
            }
            if ASCEND_IS_AIV {
                AscendC::NotifyFunc<false>((GM_ADDR)task->args);
            }
        } else if (task->type == SkTaskType::TYPE_EVENT_WAIT) {
            if ASCEND_IS_AIC {
                AscendC::WaitFunc<true>((GM_ADDR)task->args);
            }
            if ASCEND_IS_AIV {
                AscendC::WaitFunc<false>((GM_ADDR)task->args);
            }
        }
    }
    pipe_barrier(PIPE_ALL);
}

extern "C" __global__ __mix__(0, 1) void sk_entry_aiv(GM_ADDR skDevArgs)
{
    spk_entry_impl<0, 1, false>(skDevArgs);
}

extern "C" __global__ __mix__(1, 0) void sk_entry_aic(GM_ADDR skDevArgs)
{
    spk_entry_impl<1, 0, false>(skDevArgs);
}

extern "C" __global__ __mix__(1, 1) void sk_entry_mix11(GM_ADDR skDevArgs)
{
    spk_entry_impl<1, 1, false>(skDevArgs);
}

extern "C" __global__ __mix__(1, 2) void sk_entry_mix12(GM_ADDR skDevArgs)
{
    spk_entry_impl<1, 2, false>(skDevArgs);
}

extern "C" __global__ __mix__(0, 1) void sk_entry_aiv_debug(GM_ADDR skDevArgs)
{
    spk_entry_impl<0, 1, true>(skDevArgs);
}

extern "C" __global__ __mix__(1, 0) void sk_entry_aic_debug(GM_ADDR skDevArgs)
{
    spk_entry_impl<1, 0, true>(skDevArgs);
}

extern "C" __global__ __mix__(1, 1) void sk_entry_mix11_debug(GM_ADDR skDevArgs)
{
    spk_entry_impl<1, 1, true>(skDevArgs);
}

extern "C" __global__ __mix__(1, 2) void sk_entry_mix12_debug(GM_ADDR skDevArgs)
{
    spk_entry_impl<1, 2, true>(skDevArgs);
}
