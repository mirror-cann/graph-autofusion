From 5d81a390f7cfe1dc6a1cc57788694fcc01447634 Mon Sep 17 00:00:00 2001
From: neo <niuyuhucs@google.com>
Date: Mon, 13 Jul 2026 02:29:20 -0700
Subject: [PATCH] Add custom broadcast emitter (hand-written VecBroadcast
 printer)

The auto-generated emitter cannot express broadcast_l2's C++ form
`AscendC::Broadcast<T, dim, axis>(dst, src, dstShape[], srcShape[])`:
it needs two non-type template params (dim AND axis), the two LocalTensor
operands share one element type, and the shape variadics must become stack
`uint32_t[]` arrays. So:

- OpVecBroadcastExt.td: drop the `AscFunc` trait + `paramTypeLists` so the
  auto emitter steps aside for broadcast_l2.
- Translation.cpp: register `BroadcastL2Op` in PrintableOpTypes + include the
  hand-written header.
- Basic/VecBroadcast.{cpp,h}: the hand-written printer (recovers `axis` from
  the src==1/dst!=1 dimension; rank from `constRank`).
---
 .../Dialect/Asc/IR/Basic/OpVecBroadcastExt.td |  9 ++-
 include/ascir/Target/Asc/Basic/VecBroadcast.h | 28 ++++++++
 lib/Target/AscendC/Basic/VecBroadcast.cpp     | 65 +++++++++++++++++++
 lib/Target/AscendC/Translation.cpp            |  3 +
 4 files changed, 103 insertions(+), 2 deletions(-)
 create mode 100644 include/ascir/Target/Asc/Basic/VecBroadcast.h
 create mode 100644 lib/Target/AscendC/Basic/VecBroadcast.cpp

diff --git a/include/ascir/Dialect/Asc/IR/Basic/OpVecBroadcastExt.td b/include/ascir/Dialect/Asc/IR/Basic/OpVecBroadcastExt.td
index 17fe5fe..0861b63 100644
--- a/include/ascir/Dialect/Asc/IR/Basic/OpVecBroadcastExt.td
+++ b/include/ascir/Dialect/Asc/IR/Basic/OpVecBroadcastExt.td
@@ -20,7 +20,13 @@ include "mlir/Interfaces/CastInterfaces.td"
 include "mlir/Interfaces/SideEffectInterfaces.td"
 include "mlir/IR/OpBase.td"
 
-def AscendC_BroadcastL2Op : VectorOp<"broadcast_l2", "Broadcast", [AscFunc, AttrSizedOperandSegments]> {
+// NOTE: no `AscFunc` trait — the auto-generated emitter cannot express this op's
+// C++ form (`AscendC::Broadcast<T, dim, axis>(dst, src, dstShape[], srcShape[])`):
+// it needs two non-type template params (dim AND axis), the two LocalTensor
+// operands share one element type, and the shape variadics must become stack
+// `uint32_t[]` arrays rather than a `reinterpret_cast`. A hand-written printer in
+// lib/Target/AscendC/Basic/VecBroadcast.cpp handles all of that instead.
+def AscendC_BroadcastL2Op : VectorOp<"broadcast_l2", "Broadcast", [AttrSizedOperandSegments]> {
     let description = "Broadcast elements from source tensor to destination tensor (L2 API)";
     let arguments = (ins
         AscendC_LocalTensor:$dst,
@@ -29,7 +35,6 @@ def AscendC_BroadcastL2Op : VectorOp<"broadcast_l2", "Broadcast", [AscFunc, Attr
         Variadic<I32>:$srcShape,
         I32Attr:$constRank
     );
-    let paramTypeLists = [2, 2, -2, -2, 4];
 }
 
 #endif //ASC_BASIC_OP_VEC_BROADCAST_EXT_TD
