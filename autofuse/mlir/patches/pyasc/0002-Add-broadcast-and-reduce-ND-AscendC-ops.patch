+#ifndef ASC_BASIC_OP_VEC_BROADCAST_EXT_TD
+#define ASC_BASIC_OP_VEC_BROADCAST_EXT_TD
+
+include "Base.td"
+include "Core/Attributes.td"
+include "Core/Interfaces.td"
+include "Core/Types.td"
+
+include "mlir/Interfaces/CastInterfaces.td"
+include "mlir/Interfaces/SideEffectInterfaces.td"
+include "mlir/IR/OpBase.td"
+
+def AscendC_BroadcastL2Op : VectorOp<"broadcast_l2", "Broadcast", [AscFunc, AttrSizedOperandSegments]> {
+    let description = "Broadcast elements from source tensor to destination tensor (L2 API)";
+    let arguments = (ins
+        AscendC_LocalTensor:$dst,
+        AscendC_LocalTensor:$src,
+        Variadic<I32>:$dstShape,
+        Variadic<I32>:$srcShape,
+        I32Attr:$constRank
+    );
+    let paramTypeLists = [2, 2, -2, -2, 4];
+}
+
+#endif //ASC_BASIC_OP_VEC_BROADCAST_EXT_TD
diff --git a/include/ascir/Dialect/Asc/IR/Basic/OpVecReduceND.td b/include/ascir/Dialect/Asc/IR/Basic/OpVecReduceND.td
new file mode 100644
index 0000000..5c1fa0f
--- /dev/null
+++ b/include/ascir/Dialect/Asc/IR/Basic/OpVecReduceND.td
@@ -0,0 +1,60 @@
+/*
+ * Copyright (c) 2025 Huawei Technologies Co., Ltd.
+ * This program is free software, you can redistribute it and/or modify it under the terms and conditions of
+ * CANN Open Software License Agreement Version 2.0 (the "License").
+ * Please refer to the License for details. You may not use this file except in compliance with the License.
+ * THIS SOFTWARE IS PROVIDED ON AN "AS IS" BASIS, WITHOUT WARRANTIES OF ANY KIND, EITHER EXPRESS OR IMPLIED,
+ * INCLUDING BUT NOT LIMITED TO NON-INFRINGEMENT, MERCHANTABILITY, OR FITNESS FOR A PARTICULAR PURPOSE.
+ * See LICENSE in the root of the software repository for the full text of the License.
+ */
+
+#ifndef ASC_ADV_OP_VEC_REDUCE_ND_TD
+#define ASC_ADV_OP_VEC_REDUCE_ND_TD
+
+include "Base.td"
+include "Core/Attributes.td"
+include "Core/AttributesExt.td"
+include "Core/Interfaces.td"
+include "Core/Types.td"
+
+include "mlir/Interfaces/SideEffectInterfaces.td"
+include "mlir/IR/OpBase.td"
+
+
+class BaseReduceNDL2Op<string mnemonic, string apiName, list<Trait> traits = []>
+    : VectorOp<mnemonic, apiName, [OpWithDstInterface, AscFunc] # traits> {
+  let arguments = (ins
+    AscendC_LocalTensor:$dst,
+    AscendC_LocalTensor:$src,
+    AscendC_ReduceLayoutAttr:$layout,
+    Optional<AscendC_LocalTensor>:$sharedTmpBuffer
+  );
+  let paramTypeLists = [0, 0, 3, 0];
+  let description = [{
+    Generic reduce operation with configurable layout.
+
+    Computes reduction on `src` tensor and stores result in `dst`.
+    Layout parameter determines the dimension ordering:
+    - AR: Reduce along R dimension of shape [A, R]
+    - RA: Reduce along R dimension of shape [R, A]
+
+    `sharedTmpBuffer`, when present, provides a scratch space for temporary storage.
+  }];
+  let extraClassDeclaration = extraClassDeclarationBase # [{
+    bool isARLayout() {
+      return getLayout() == ReduceLayout::AR;
+    }
+
+    bool isRALayout() {
+      return getLayout() == ReduceLayout::RA;
+    }
+  }];
+}
+
+def AscendC_ReduceSum2DL2Op : BaseReduceNDL2Op<"reduce_sum_2d_l2", "ReduceSum">;
+def AscendC_ReduceMin2DL2Op : BaseReduceNDL2Op<"reduce_min_2d_l2", "ReduceMin">;
+def AscendC_ReduceMax2DL2Op : BaseReduceNDL2Op<"reduce_max_2d_l2", "ReduceMax">;
+def AscendC_ReduceProd2DL2Op : BaseReduceNDL2Op<"reduce_prod_2d_l2", "ReduceProd">;
+
+
+#endif // ASC_ADV_OP_VEC_REDUCE_ND_TD
