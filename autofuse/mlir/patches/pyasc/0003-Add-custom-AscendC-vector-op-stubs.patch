+#ifndef ASC_BASIC_OP_VEC_ACTIVATION_EXT_TD
+#define ASC_BASIC_OP_VEC_ACTIVATION_EXT_TD
+
+include "Base.td"
+include "Core/Attributes.td"
+include "Core/Interfaces.td"
+include "Core/Types.td"
+
+include "mlir/Interfaces/CastInterfaces.td"
+include "mlir/Interfaces/SideEffectInterfaces.td"
+include "mlir/IR/OpBase.td"
+
+def AscendC_GeluOp : MathLibraryOp<"gelu", "Gelu", [AttrSizedOperandSegments]> {
+  let description = "`AscendC::Gelu` Gaussian Error Linear Unit activation function.\n";
+  let arguments = (ins AscendC_LocalTensor:$dst, AnyType:$src,
+                   Optional<AnyType>:$sharedTmpBuffer, Optional<AnyType>:$calCount,
+                   UnitAttr:$highPrecision, UnitAttr:$highPerformance);
+}
+
+def AscendC_SigmoidOp : MathLibraryOp<"sigmoid", "Sigmoid", [AttrSizedOperandSegments]> {
+  let description = "`AscendC::Sigmoid` sigmoid activation function.\n";
+  let arguments = (ins AscendC_LocalTensor:$dst, AnyType:$src,
+                   Optional<AnyType>:$sharedTmpBuffer, Optional<AnyType>:$calCount);
+}
+
+def AscendC_SiluOp : MathLibraryOp<"silu", "Silu", [AttrSizedOperandSegments]> {
+  let description = "`AscendC::Silu` SiLU (Swish) activation function.\n";
+  let arguments = (ins AscendC_LocalTensor:$dst, AnyType:$src,
+                   Optional<AnyType>:$sharedTmpBuffer, Optional<AnyType>:$calCount);
+}
+
+def AscendC_SwishOp : MathLibraryOp<"swish", "Swish", [AttrSizedOperandSegments]> {
+  let description = "`AscendC::Swish` Swish activation function (same as SiLU).\n";
+  let arguments = (ins AscendC_LocalTensor:$dst, AnyType:$src,
+                   Optional<AnyType>:$sharedTmpBuffer, Optional<AnyType>:$calCount);
+}
+
+def AscendC_LogSoftmaxOp : MathLibraryOp<"log_softmax", "LogSoftmax", [AttrSizedOperandSegments]> {
+  let description = "`AscendC::LogSoftmax` log softmax activation function.\n";
+  let arguments = (ins AscendC_LocalTensor:$dst, AnyType:$src,
+                   Optional<AnyType>:$sharedTmpBuffer, Optional<AnyType>:$calCount,
+                   AnyType:$axis);
+}
+
+def AscendC_GeGLUOp : MathLibraryOp<"geglu", "GeGLU", [AttrSizedOperandSegments]> {
+  let description = "`AscendC::GeGLU` GELU-gated Linear Unit.\n";
+  let arguments = (ins AscendC_LocalTensor:$dst, AnyType:$src0, AnyType:$src1,
+                   Optional<AnyType>:$sharedTmpBuffer, Optional<AnyType>:$calCount);
+}
+
+def AscendC_SwiGLUOp : MathLibraryOp<"swiglu", "SwiGLU", [AttrSizedOperandSegments]> {
+  let description = "`AscendC::SwiGLU` Swish-gated Linear Unit.\n";
+  let arguments = (ins AscendC_LocalTensor:$dst, AnyType:$src0, AnyType:$src1,
+                   Optional<AnyType>:$sharedTmpBuffer, Optional<AnyType>:$calCount);
+}
+
+def AscendC_ReGLUOp : MathLibraryOp<"reglu", "ReGLU", [AttrSizedOperandSegments]> {
+  let description = "`AscendC::ReGLU` ReLU-gated Linear Unit.\n";
+  let arguments = (ins AscendC_LocalTensor:$dst, AnyType:$src0, AnyType:$src1,
+                   Optional<AnyType>:$sharedTmpBuffer, Optional<AnyType>:$calCount);
+}
+
+def AscendC_ClipByValueOp : MathLibraryOp<"clip_by_value", "ClipByValue", [AttrSizedOperandSegments]> {
+  let description = "`AscendC::ClipByValue` clips tensor values to a specified range.\n";
+  let arguments = (ins AscendC_LocalTensor:$dst, AnyType:$src, AnyType:$clipValueMin, AnyType:$clipValueMax,
+                   Optional<AnyType>:$sharedTmpBuffer, Optional<AnyType>:$calCount);
+}
+
+def AscendC_GeluExtendOp : MathLibraryOp<"gelu_extend", "GeluExtend", [AttrSizedOperandSegments]> {
+  let description = "`AscendC::GeluExtend` GELU activation function extended implementation.\n";
+  let arguments = (ins AscendC_LocalTensor:$dst, AnyType:$src, AnyType:$count);
+}
+
+def AscendC_SigmoidExtendOp : MathLibraryOp<"sigmoid_extend", "SigmoidExtend", [AttrSizedOperandSegments]> {
+  let description = "`AscendC::SigmoidExtend` sigmoid activation function extended implementation with tmp buffer.\n";
+  let arguments = (ins AscendC_LocalTensor:$dst, AnyType:$src, AnyType:$calCount, AscendC_LocalTensor:$tmpBuf);
+}
+
+#endif // ASC_BASIC_OP_VEC_ACTIVATION_EXT_TD
