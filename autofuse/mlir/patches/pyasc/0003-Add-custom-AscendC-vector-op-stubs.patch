+ */
+
+#ifndef ASC_BASIC_OP_VEC_DATA_MOVE_EXT_TD
+#define ASC_BASIC_OP_VEC_DATA_MOVE_EXT_TD
+
+include "Base.td"
+include "Core/Attributes.td"
+include "Core/Interfaces.td"
+include "Core/Types.td"
+
+include "mlir/Interfaces/CastInterfaces.td"
+include "mlir/Interfaces/SideEffectInterfaces.td"
+include "mlir/IR/OpBase.td"
+
+class DataMoveOp<string mnemonic, string apiName, list<Trait> traits = []>
+    : VectorOp<mnemonic, apiName, [AscFunc] # traits> {
+  let description = "`AscendC::" # apiName # "` is a data movement operation.\n";
+}
+
+def AscendC_BroadcastOp : DataMoveOp<"broadcast", "Broadcast"> {
+  let description = "Broadcast tensor to target shape (main entry point).\n";
+  let arguments = (ins AscendC_LocalTensor:$dst, AscendC_LocalTensor:$src,
+                   AscendC_LocalTensor:$sharedTmpBuffer,
+                   AnyType:$srcM, AnyType:$srcK, AnyType:$srcZ,
+                   AnyType:$dstM, AnyType:$dstK, AnyType:$dstZ);
+}
+
+def AscendC_BroadcastFirstDimOp : DataMoveOp<"broadcast_first_dim", "BroadcastFirstDim"> {
+  let description = "Broadcast first dimension (1,B) -> (A,B) or (1,B,C) -> (A,B,C).\n";
+  let arguments = (ins AscendC_LocalTensor:$dst, AscendC_LocalTensor:$src,
+                   AnyType:$srcM, AnyType:$srcK, AnyType:$srcZ,
+                   AnyType:$dstM, AnyType:$dstK, AnyType:$dstZ,
+                   AscendC_LocalTensor:$tmpBuf);
+}
+
+def AscendC_BroadcastMiddleDimOp : DataMoveOp<"broadcast_middle_dim", "BroadcastMiddleDim"> {
+  let description = "Broadcast middle dimension (A,1) -> (A,B) or (A,1,C) -> (A,B,C).\n";
+  let arguments = (ins AscendC_LocalTensor:$dst, AscendC_LocalTensor:$src,
+                   AnyType:$srcM, AnyType:$srcK, AnyType:$srcZ,
+                   AnyType:$dstM, AnyType:$dstK, AnyType:$dstZ,
+                   AscendC_LocalTensor:$tmpBuf);
+}
+
+def AscendC_BroadcastMiddleDimWithCopyOp : DataMoveOp<"broadcast_middle_dim_with_copy", "BroadcastMiddleDimWithCopy"> {
+  let description = "Broadcast middle dimension using Copy operation.\n";
+  let arguments = (ins AscendC_LocalTensor:$dst, AscendC_LocalTensor:$src,
+                   AnyType:$srcM, AnyType:$srcK, AnyType:$srcZ,
+                   AnyType:$dstM, AnyType:$dstK, AnyType:$dstZ,
+                   AscendC_LocalTensor:$tmpBuf, AnyType:$lastDimStride);
+}
+
+def AscendC_BroadcastWithStrideOp : DataMoveOp<"broadcast_with_stride", "BroadcastWithStride"> {
+  let description = "Broadcast with stride for non-contiguous memory.\n";
+  let arguments = (ins AscendC_LocalTensor:$dst, AscendC_LocalTensor:$src,
+                   AnyType:$srcM, AnyType:$srcK, AnyType:$srcZ,
+                   AnyType:$dstM, AnyType:$dstK, AnyType:$dstZ,
+                   AscendC_LocalTensor:$tmpBuf);
+}
+
+def AscendC_BroadcastCommonOp : DataMoveOp<"broadcast_common", "BroadcastCommon"> {
+  let description = "Common broadcast implementation with type dispatch.\n";
+  let arguments = (ins AscendC_LocalTensor:$dst, AscendC_LocalTensor:$src,
+                   AnyType:$srcM, AnyType:$srcK, AnyType:$srcZ,
+                   AnyType:$dstM, AnyType:$dstK, AnyType:$dstZ,
+                   AscendC_LocalTensor:$tmpBuf, AnyType:$lastDimStride);
+}
+
+def AscendC_BroadcastWithCastOp : DataMoveOp<"broadcast_with_cast", "BroadcastWithCast"> {
+  let description = "Broadcast with type cast for uint8/int8 types.\n";
+  let arguments = (ins AscendC_LocalTensor:$dst, AscendC_LocalTensor:$src,
+                   AnyType:$srcM, AnyType:$srcK, AnyType:$srcZ,
+                   AnyType:$dstM, AnyType:$dstK, AnyType:$dstZ,
+                   AscendC_LocalTensor:$tmpBuf, AnyType:$lastDimStride);
+}
+
+def AscendC_BroadcastInt64Op : DataMoveOp<"broadcast_int64", "BroadcastInt64"> {
+  let description = "Broadcast for int64/uint64 types (special handling).\n";
+  let arguments = (ins AscendC_LocalTensor:$dst, AscendC_LocalTensor:$src,
+                   AnyType:$srcM, AnyType:$srcK, AnyType:$srcZ,
+                   AnyType:$dstM, AnyType:$dstK, AnyType:$dstZ,
+                   AscendC_LocalTensor:$tmpBuf, AnyType:$lastDimStride);
+}
+
+def AscendC_BroadcastInt64LastDimOp : DataMoveOp<"broadcast_int64_last_dim", "BroadcastInt64LastDim"> {
+  let description = "Broadcast last dimension for int64 type.\n";
+  let arguments = (ins AscendC_LocalTensor:$dst, AscendC_LocalTensor:$src,
+                   AnyType:$srcM, AnyType:$srcK, AnyType:$srcZ,
+                   AnyType:$dstM, AnyType:$dstK, AnyType:$dstZ,
+                   AscendC_LocalTensor:$calcBuf, AnyType:$lastDimStride);
+}
+
+def AscendC_BrcbSrcToOneBlockOp : DataMoveOp<"brcb_src_to_one_block", "BrcbSrcToOneBlock"> {
+  let description = "Broadcast source data to one block size.\n";
+  let arguments = (ins AscendC_LocalTensor:$src, AnyType:$firstDim,
+                   AnyType:$oneBlkNum, AscendC_LocalTensor:$brcbBuf);
+}
+
+def AscendC_GatherOp : DataMoveOp<"gather", "Gather"> {
+  let description = "Gather elements from source tensor.\n";
+  let arguments = (ins AscendC_LocalTensor:$dst, AscendC_LocalTensor:$src,
+                   AnyType:$indices, AnyType:$calCount);
+}
+
+def AscendC_ScatterOp : DataMoveOp<"scatter", "Scatter"> {
+  let description = "Scatter elements to destination tensor.\n";
+  let arguments = (ins AscendC_LocalTensor:$dst, AscendC_LocalTensor:$src,
+                   AnyType:$indices, AnyType:$calCount);
+}
+
+def AscendC_ConcatOp : DataMoveOp<"concat", "Concat", [AttrSizedOperandSegments]> {
+  let description = "Concatenate tensors along an axis.\n";
+  let arguments = (ins AscendC_LocalTensor:$dst, Variadic<AscendC_LocalTensor>:$srcList,
+                   AnyType:$axis, AnyType:$calCount);
+}
+
+def AscendC_SplitOp : DataMoveOp<"split", "Split", [AttrSizedOperandSegments]> {
+  let description = "Split tensor along an axis.\n";
+  let arguments = (ins Variadic<AscendC_LocalTensor>:$dstList, AscendC_LocalTensor:$src,
+                   AnyType:$axis, AnyType:$splitSizes);
+}
+
+def AscendC_RemovePadOp : DataMoveOp<"remove_pad", "RemovePad"> {
+  let description = "Remove padding from tensor.\n";
+  let arguments = (ins AscendC_LocalTensor:$dst, AscendC_LocalTensor:$src,
+                   AnyType:$calCount);
+}
+
+def AscendC_InterleaveOp : DataMoveOp<"interleave", "Interleave"> {
+  let description = "Interleave two tensors.\n";
+  let arguments = (ins AscendC_LocalTensor:$dst, AscendC_LocalTensor:$src0,
+                   AscendC_LocalTensor:$src1, AnyType:$calCount);
+}
+
+def AscendC_DeInterleaveOp : DataMoveOp<"deinterleave", "DeInterleave"> {
+  let description = "De-interleave tensor into two tensors.\n";
+  let arguments = (ins AscendC_LocalTensor:$dst0, AscendC_LocalTensor:$dst1,
+                   AscendC_LocalTensor:$src, AnyType:$calCount);
+}
+
+def AscendC_GatherExtendOp : DataMoveOp<"gather_extend", "GatherExtend"> {
+  let description = "Gather elements from global tensor with extended support.\n";
+  let arguments = (ins AscendC_LocalTensor:$dst, AnyType:$src0, AnyType:$src1,
+                   AnyType:$paramLastAxisSize, AnyType:$vectorizedAxisSize,
+                   AscendC_LocalTensor:$tmpBuf);
+}
+
+#endif // ASC_BASIC_OP_VEC_DATA_MOVE_EXT_TD
